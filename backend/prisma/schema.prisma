// This is your Prisma schema file,
// learn more about it in the docs: https://pris.ly/d/prisma-schema

// Get a free hosted Postgres database in seconds: `npx create-db`

generator client {
  provider = "prisma-client-js"
  engineType = "library"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

model User {
  id        Int      @id @default(autoincrement())
  username  String   @unique
  password  String?  // Optional for Google users
  googleId  String?  @unique
  avatarUrl String?
  wins      Int      @default(0)
  losses    Int      @default(0)
  coins     Int      @default(25000)
  createdAt DateTime @default(now())
  
  friends        Friendship[] @relation("UserFriends")
  friendRequests Friendship[] @relation("FriendRequests")
  matches        MatchPlayer[]
}

model Friendship {
  id        Int      @id @default(autoincrement())
  userId    Int
  friendId  Int
  status    String   // 'PENDING', 'ACCEPTED'
  
  user      User     @relation("UserFriends", fields: [userId], references: [id])
  friend    User     @relation("FriendRequests", fields: [friendId], references: [id])
}

model MatchHistory {
  id             Int      @id @default(autoincrement())
  roomId         String
  winnerUsername String?
  playedAt       DateTime @default(now())
  
  players        MatchPlayer[]
}

model MatchPlayer {
  id          Int      @id @default(autoincrement())
  matchId     Int
  userId      Int?     // Nullable for bots
  username    String   // Storing name directly for bots and easy display
  score       Int
  isWinner    Boolean  @default(false)
  
  match       MatchHistory @relation(fields: [matchId], references: [id])
  user        User?        @relation(fields: [userId], references: [id])
}

